# ─── Database ─────────────────────────────────────────────────
DB_USER=postgres
DB_HOST=localhost
DB_NAME=myapp
DB_PASSWORD=secret
DB_PORT=5432

JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d


QSTASH_TOKEN=your_qstash_token_here
QSTASH_CURRENT_SIGNING_KEY=your_current_signing_key_here
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key_here


APP_BASE_URL=http://localhost:3000

NODE_ENV=development
PORT=3000


# ─── Production (Render) ──────────────────────────────────────
PORT_PROD=your_render_db_host
DATABASE_PROD=your_db_name
USERNAME_PROD=your_db_user
PASSWORD_PROD=your_db_password
INTERNAL_DATABASE_URL_PROD=postgresql://user:pass@host/db
EXTERNAL_DATABASE_URL_PROD=postgresql://user:pass@host.onrender.com/db